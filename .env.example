COMPOSE_PROJECT_NAME=grafrag-experimentation

OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENWEBUI_ENV=prod
PIPELINES_IMAGE=ghcr.io/open-webui/pipelines:main
REGISTRY=ghcr.io/example
REGISTRY_SERVER=ghcr.io
REGISTRY_USERNAME=CHANGE_ME
REGISTRY_PASSWORD=CHANGE_ME
REGISTRY_EMAIL=ops@fake-domain.change.me
IMAGE_TAG=0.1.0

OPENWEBUI_PORT=3000
OPENWEBUI_PUBLIC_URL=http://localhost:3000
PIPELINES_PORT=9099
BRIDGE_PORT=8081
BRIDGE_PUBLIC_URL=http://localhost:8081
KEYCLOAK_PORT=8082
KEYCLOAK_PUBLIC_URL=http://localhost:8082
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=openwebui
GRAPH_VIEWER_CLIENT_ID=graphrag-viewer
GRAPH_VIEWER_AUTH_REQUIRED=true

SCW_LLM_BASE_URL=https://api.scaleway.ai/a9158aac-8404-46ea-8bf5-1ca048cd6ab4/v1
SCW_SECRET_KEY_LLM=CHANGE_ME
SCW_LLM_MODEL=mistral-small-3.2-24b-instruct-2506
OPENAI_EMBEDDING_MODEL=bge-multilingual-gemma2

PIPELINES_API_KEY=CHANGE_ME
WEBUI_SECRET_KEY=CHANGE_ME
ENABLE_LOGIN_FORM=false
ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true

SEARXNG_IMAGE=docker.io/searxng/searxng:latest
VALKEY_IMAGE=docker.io/valkey/valkey:8-alpine
SEARXNG_REPLICAS=2
SEARXNG_LOCAL_PORT=8083
SEARXNG_LOCAL_BASE_URL=http://localhost:8083
SEARXNG_HOST=search.fake-domain.change.me
SEARXNG_TLS_SECRET_NAME=search-tls
SEARXNG_SECRET=CHANGE_ME
SEARXNG_OUTBOUND_PROXY_PAR_URL=http://search-egress-par.example.internal:8080
SEARXNG_OUTBOUND_PROXY_AMS_URL=http://search-egress-ams.example.internal:8080
SEARXNG_OUTBOUND_PROXY_WAW_URL=http://search-egress-waw.example.internal:8080

GRAPHRAG_METHOD=local
GRAPHRAG_RESPONSE_TYPE="Multiple Paragraphs"
GRAPHRAG_ROOT=/app/graphrag
GRAPHRAG_INPUT_DIR=/app/graphrag/input
GRAPHRAG_OUTPUT_DIR=/app/graphrag/output
GRAPHRAG_TOP_K=4
GRAPHRAG_CACHE_S3_ENABLED=false
GRAPHRAG_CACHE_S3_BUCKET=
GRAPHRAG_CACHE_S3_PREFIX=graphrag/cache
GRAPHRAG_CACHE_S3_REGION=
GRAPHRAG_CACHE_S3_ENDPOINT_URL=
GRAPHRAG_CACHE_S3_ACCESS_KEY_ID=
GRAPHRAG_CACHE_S3_SECRET_ACCESS_KEY=
GRAPHRAG_CACHE_S3_SESSION_TOKEN=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

NAMESPACE=grafrag
BASE_DOMAIN=fake-domain.change.me
OPENWEBUI_HOST=openwebui.fake-domain.change.me
KEYCLOAK_HOST=openwebui-sso.fake-domain.change.me
LETSENCRYPT_EMAIL=ops@fake-domain.change.me
TLS_SECRET_NAME=openwebui-tls
KEYCLOAK_TLS_SECRET_NAME=keycloak-tls
